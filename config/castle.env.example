# Claude Castle settings. THIS FILE HOLDS NO SECRETS ANYMORE.
#
# Secrets live in the vault: one Scaleway Secret Manager secret named
# "castle-env" whose latest version holds the stack's FULL environment
# (the settings block below PLUS the vault section below it). Every change
# is a new version, pushed with infra/secrets/push-env.sh. The VM pulls
# the latest version into its private cache at /opt/castle/castle.env
# (mode 600), and docker compose reads that cache. See
# infra/secrets/README.md.
#
# The onboard skill copies ONLY the settings block of this file to
# config/castle.env on your laptop, for quick reads (which server, which
# domain). The vault section stays here as documentation of what exists;
# those values never land in config/castle.env.
# NEVER commit castle.env; git ignores it. Only this .example file lives in git.

# =============================================================================
# SETTINGS: kept in config/castle.env on the laptop. Nothing secret here.
# =============================================================================
CASTLE_DOMAIN=castle.example.com
CASTLE_REGION=fr-par
GITHUB_REPO=yourname/claude-castle
# Filled in by onboard when the server exists.
SERVER_IP=

# --- Optional: email sending for documents (settings, not secrets) ---------
# Filled in the first time you ask Claude to email a document (the
# make-document skill). Needs a real domain verified for sending at
# Scaleway; free sslip.io names cannot send. See infra/email/README.md.
# The sending credential is the Scaleway secret key, which the send script
# reads from the scw CLI config, never from this file.
TEM_PROJECT_ID=
TEM_REGION=fr-par
TEM_FROM=

# =============================================================================
# GOES INTO THE VAULT: onboard assembles these in a temporary file (never
# in config/castle.env), pushes them to the castle-env secret, and deletes
# the temporary file. Documented here so you know what exists; the real
# values live only in the vault and in the VM's pulled cache.
#
# The vault version contains the FULL environment: the settings block above
# is repeated inside it (compose needs CASTLE_DOMAIN and GITHUB_REPO too).
# =============================================================================

# --- Notulen dashboard login (onboard generates the hash) -----------------------
NOTULEN_BASIC_AUTH_USER=castle
# bcrypt hash from `docker compose exec caddy caddy hash-password`.
# Wrap it in single quotes, it contains $ characters.
NOTULEN_BASIC_AUTH_HASH=

# --- Database (runs inside the stack, onboard generates passwords) --------------
POSTGRES_USER=castle
POSTGRES_PASSWORD=
POSTGRES_DB=castle
NEXTCLOUD_DB_NAME=nextcloud
NEXTCLOUD_DB_USER=nextcloud
NEXTCLOUD_DB_PASSWORD=

# --- Nextcloud first admin account (created on first boot) ----------------------
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=

# --- Notulen: object storage for audio (onboard fills these) --------------------
S3_ENDPOINT=https://s3.fr-par.scw.cloud
S3_REGION=fr-par
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- Notulen: minutes writing ----------------------------------------------------
# Anthropic API key, separate billing from your claude.ai subscription.
ANTHROPIC_API_KEY=
# Language the minutes are written in (nl or en).
MINUTES_LANGUAGE=nl

# --- Optional: publish finished minutes to your GitHub repo ----------------------
# Leave empty to keep minutes only in the dashboard.
NOTULEN_GITHUB_REPO=
NOTULEN_GITHUB_PAT=
NOTULEN_GITHUB_BRANCH=main
NOTULEN_TARGET_DIR=minutes/

# --- Cloud folder to GitHub sync (optional feature, required secret) -------------
# Anything a user drops in the "Sync" folder of their Nextcloud files gets
# committed to your GitHub repo under cloud-sync/<username>/.
# NEXTCLOUD_WEBHOOK_SECRET must always be set (the stack refuses to start
# without it); onboard generates it with `openssl rand -hex 24`.
NEXTCLOUD_WEBHOOK_SECRET=
# Fine-grained GitHub token that lets the sync write files to your repo.
# Make one at github.com/settings/personal-access-tokens: choose your castle
# repo as the only repository and give it Contents read and write, nothing else.
# Leave empty to keep the sync off; everything else works without it.
SYNC_GITHUB_PAT=
# Defaults: folder "Sync" in each user's files, landing in cloud-sync/ in the
# repo. Uncomment to change.
#NC_SYNC_FOLDER=Sync
#SYNC_TARGET_DIR=cloud-sync/

# --- Optional: GPU transcription upgrade -----------------------------------------
# Leave all of these empty: CPU transcription works without them. When you
# turn the GPU tier on, onboard's GPU phase fills them in automatically.
# Base64-encoded kubeconfig of the castle GPU cluster (the dashboard uses it
# to submit transcription Jobs).
KUBECONFIG_DATA=
# Kubernetes namespace the Jobs run in; onboard sets "castle".
CASTLE_K8S_NAMESPACE=
# The worker image onboard builds and pushes (a pinned tag, not :latest).
NOTULEN_WORKER_IMAGE=
# Name of the registry pull secret in that namespace; onboard sets
# "castle-registry".
CASTLE_IMAGE_PULL_SECRET=
# The external database address GPU workers use to reach this stack from
# the cluster (server IP, not the in-stack "postgres" hostname).
DB_URL_OPS=
# Optional: Hugging Face token for speaker labels in the transcripts.
# Without it everything still works, the whole meeting is just labeled as
# one speaker. See infra/docker/notulen-worker/Dockerfile for how to get
# the token and rebuild the worker image with it.
HF_TOKEN=
